# LLM Provider — pick one
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Database
POSTGRES_DB=mem0
POSTGRES_USER=mem0
POSTGRES_PASSWORD=changeme

# Auth — generate with: openssl rand -base64 48
JWT_SECRET=your-secret-key-here

# Dashboard CORS origin (set to dashboard domain when deployed)
DASHBOARD_URL=http://localhost:3000

# Public API URL for dashboard to call (set when deployed via Coolify)
MEM0_API_URL=http://localhost:8888

# Optional settings
AUTH_DISABLED=false
MEM0_TELEMETRY=false
MEM0_DEFAULT_LLM_MODEL=gpt-4o-mini
MEM0_DEFAULT_EMBEDDER_MODEL=text-embedding-3-small
REQUEST_LOG_RETENTION_DAYS=30
